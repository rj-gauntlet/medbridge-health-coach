# MedBridge AI Health Coach - Environment Configuration
# Copy this file to .env and fill in your values.

# OpenAI API Key (required for LLM)
OPENAI_API_KEY=sk-...

# Database (SQLite path; leave empty for default: ./data/coach.db)
DATABASE_URL=sqlite:///./data/coach.db

# Optional: Override default model
# OPENAI_MODEL=gpt-4o-mini

# Optional: Demo mode - 1 "day" = 60 seconds (default 86400 = real day)
# SCHEDULER_DAY_SECONDS=60
